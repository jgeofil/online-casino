rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for User Balance
    function isValidUser(data) {
      return data.balance is number 
        && data.totalSpins is number 
        && (data.keys().hasAll(['balance', 'totalSpins', 'updatedAt']) && data.keys().size() == 3);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.updatedAt == request.time;
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'totalSpins', 'updatedAt']);
    }

    // Helper for Withdrawals
    function isValidWithdrawal(data) {
      return data.userId is string && data.userId == request.auth.uid
        && data.address is string && data.address.size() >= 10 && data.address.size() <= 256
        && data.amount is number && data.amount > 0
        && data.status == 'pending'
        && data.createdAt == request.time
        && (data.keys().hasAll(['userId', 'address', 'amount', 'status', 'createdAt']) && data.keys().size() == 5);
    }

    match /withdrawals/{withdrawalId} {
      allow create: if isSignedIn() 
        && isValidWithdrawal(request.resource.data)
        // Ensure user balance is updated in the same batch (decrement)
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.balance == 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.balance - request.resource.data.amount;
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
